    <h1 class="legal__title">Privacy Policy</h1>
    <p class="legal__lead">How we handle data when you visit {{ site.url }}.</p>

    <h2>1. Data controller</h2>
    <p>
      {{ site.name }}<br>
      {{ site.address.street }}<br>
      {{ site.address.postalCode }} {{ site.address.city }}<br>
      Denmark
