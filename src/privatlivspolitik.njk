    <h1 class="legal__title">Privatlivspolitik</h1>
    <p class="legal__lead">Hvordan vi behandler oplysninger når du besøger {{ site.url }}.</p>

    <h2>1. Dataansvarlig</h2>
    <p>
      {{ site.name }}<br>
      {{ site.address.street }}<br>
      {{ site.address.postalCode }} {{ site.address.city }}<br>
      Danmark
    </p>
    <p>
