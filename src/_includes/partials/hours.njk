<section class="hours card card--ink card--tilt-l" aria-labelledby="hours-heading">
  <header class="hours__head">
    <h2 id="hours-heading" class="hours__title">ÅBNINGSTIDER</h2>
    <span class="hours__live">[LIVE]</span>
  </header>

  <dl class="hours__list">
    <div class="hours__row"><dt>MAN</dt><dd>{{ site.hours.monday }}</dd></div>
    <div class="hours__row"><dt>TIR</dt><dd>{{ site.hours.tuesday }}</dd></div>
    <div class="hours__row"><dt>ONS</dt><dd>{{ site.hours.wednesday }}</dd></div>
    <div class="hours__row"><dt>TOR</dt><dd>{{ site.hours.thursday }}</dd></div>
    <div class="hours__row hours__row--late"><dt>FRE</dt><dd>{{ site.hours.friday }} ★</dd></div>
    <div class="hours__row hours__row--late"><dt>LØR</dt><dd>{{ site.hours.saturday }} ★</dd></div>
    <div class="hours__row"><dt>SØN</dt><dd>{{ site.hours.sunday }}</dd></div>
  </dl>

  <p class="hours__note">★ = nightshift // døren går altid op for nogen</p>
</section>
