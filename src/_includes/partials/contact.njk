<article class="card card--red card--tilt-l" aria-labelledby="contact-heading">
  <div class="card__file">// KONTAKT.DUMP</div>
  <h2 id="contact-heading" class="visually-hidden">Kontakt</h2>

  <ul class="contact__list">
    <li>
      <span aria-hidden="true">📞</span>
      <a href="tel:{{ site.phoneIntl }}">{{ site.phone | replace(" ", "&nbsp;") | safe }}</a>
    </li>
    <li>
      <span aria-hidden="true">💬</span>
      <a href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}" target="_blank" rel="noopener">WHATSAPP</a>
    </li>
    <li>
      <span aria-hidden="true">◎</span>
      <a href="{{ site.instagram }}" target="_blank" rel="noopener">INSTAGRAM</a>
    </li>
  </ul>

  <a href="{{ site.bookingUrl }}" class="btn btn--ink" target="_blank" rel="noopener">Book tid <span aria-hidden="true">→</span></a>
</article>
