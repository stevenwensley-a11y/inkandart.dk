{% set lang = lang or (page.url | pageLang) %}
<section class="studio-video" aria-label="{% if lang == 'en' %}Ink &amp; Art studio video{% else %}Ink &amp; Art studievideo{% endif %}">
  <video class="studio-video__clip"
         autoplay muted loop playsinline
         preload="metadata"
         aria-hidden="true">
    <source src="/_assets/video/promo.mp4" type="video/mp4">
  </video>
  <div class="studio-video__bar" aria-hidden="true">
    <span>★ INK &amp; ART CPH</span>
    <span>LARSBJØRNSSTRÆDE 13 · KØBENHAVN</span>
  </div>
</section>
