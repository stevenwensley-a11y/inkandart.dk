<section class="hero">
  <div class="container">
    <img src="/_assets/img/logo.png" alt="{{ site.name }} logo" class="hero__logo" width="240" height="296" fetchpriority="high">
    <h1 class="hero__wordmark">{{ site.name }}</h1>
    <p class="hero__tagline">{{ site.tagline }}</p>
    <a href="{{ site.bookingUrl }}" class="btn btn--primary hero__cta" rel="noopener" target="_blank">Book tid</a>
    <nav class="hero__social" aria-label="Sociale medier">
      <a href="{{ site.instagram }}" rel="noopener" target="_blank" aria-label="Instagram">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a href="{{ site.facebook }}" rel="noopener" target="_blank" aria-label="Facebook">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
      </a>
    </nav>
  </div>
</section>
