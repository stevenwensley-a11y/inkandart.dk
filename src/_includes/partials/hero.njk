<section class="hero">
  <div class="hero__tape hero__tape--left" aria-hidden="true"></div>
  <div class="hero__tape hero__tape--right" aria-hidden="true"></div>

  <h1 class="hero__wordmark">
    <span class="hero__wordmark-line">INK <span class="amp">&amp;</span> ART</span>
    <span class="hero__wordmark-cph">COPENHAGEN<span class="dot">.</span></span>
  </h1>

  <img src="/_assets/img/logo.png"
       alt="{{ site.name }} logo"
       class="hero__logo"
       width="200" height="200"
       fetchpriority="high">

  <div class="stamp stamp--red hero__stamp-1" aria-hidden="true">Walk-ins ok</div>
  <div class="stamp stamp--ink hero__stamp-2" aria-hidden="true">No vegan ink</div>
  <div class="stamp stamp--red hero__stamp-3" aria-hidden="true">Vol.01 · zine 01</div>

  <div class="about-card">
    <div class="about-card__file">// FILE: ABOUT.TXT</div>
    <p class="about-card__text">
      Tatovør- og piercingstudio på <strong>{{ site.address.street }}</strong> — hjertet af København.
      Klassisk håndværk, fed attitude, sent åbent.
    </p>
    <div class="about-card__cta">
      <a href="{{ site.bookingUrl }}" class="btn btn--primary" target="_blank" rel="noopener">Book tid <span aria-hidden="true">→</span></a>
      <a href="tel:{{ site.phoneIntl }}" class="btn btn--ghost">Ring {{ site.phone | replace(" ", "&nbsp;") | safe }}</a>
    </div>
  </div>
</section>
