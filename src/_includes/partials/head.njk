{%- set pageLang = lang or (page.url | pageLang) -%}
{%- set pageOgImage = ogImage or (("/_assets/img/artists/" + slug + "/portrait.jpg") if slug else "/_assets/img/og-image.png") -%}
{%- set pageOgImageAlt = ogImageAlt or (site.name + " logo") -%}
{%- set pageDescription = description or site.description -%}
{%- set pageOgLocale = "en_DK" if pageLang == "en" else "da_DK" -%}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{ pageDescription }}">
<meta name="theme-color" content="#ece6da">

<link rel="preload" as="image" href="/_assets/img/logo.png" fetchpriority="high">
<link rel="preload" as="font" type="font/woff2" href="/_assets/fonts/BebasNeue-Regular.woff2" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="/_assets/fonts/SpaceMono-Regular.woff2" crossorigin>

<title>{{ title or site.name }}</title>

<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<link rel="alternate" hreflang="{{ pageLang }}" href="{{ site.url }}{{ page.url }}">
<link rel="alternate" hreflang="{% if pageLang == 'en' %}da{% else %}en{% endif %}" href="{{ site.url }}{{ page.url | sisterUrl }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{% if pageLang == 'en' %}{{ page.url | sisterUrl }}{% else %}{{ page.url }}{% endif %}">

<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" href="/_assets/img/favicon-32.png" type="image/png" sizes="32x32">
<link rel="icon" href="/_assets/img/favicon-16.png" type="image/png" sizes="16x16">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">

<meta property="og:type" content="{% if slug %}profile{% else %}website{% endif %}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ title or site.name }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:image" content="{{ site.url }}{{ pageOgImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ pageOgImageAlt }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:locale" content="{{ pageOgLocale }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title or site.name }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ site.url }}{{ pageOgImage }}">

<link rel="stylesheet" href="/_assets/css/style.css">

{% if page.url == "/404.html" %}
<meta name="robots" content="noindex, follow">
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["TattooParlor", "BeautySalon"],
      "@id": "{{ site.url }}/#business",
      "name": "{{ site.name | safe }}",
      "url": "{{ site.url }}",
      "image": "{{ site.url }}/_assets/img/og-image.png",
      "logo": "{{ site.url }}/_assets/img/logo.png",
      "description": "{{ site.description | safe }}",
      "telephone": "{{ site.phoneIntl }}",
      "additionalType": "https://en.wikipedia.org/wiki/Body_piercing",
      "areaServed": "Copenhagen",
      "knowsLanguage": ["da", "en"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ site.address.street | safe }}",
        "postalCode": "{{ site.address.postalCode }}",
        "addressLocality": "{{ site.address.city | safe }}",
        "addressCountry": "{{ site.address.country }}"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 55.6792,
        "longitude": 12.5710
      },
      "openingHoursSpecification": [
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "13:00", "closes": "23:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "13:00", "closes": "23:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "13:00", "closes": "23:30"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "13:00", "closes": "02:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "13:00", "closes": "05:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "14:00", "closes": "05:00"},
        {"@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "13:00", "closes": "23:00"}
      ],
      "sameAs": [
        "{{ site.instagram }}",
        "{{ site.facebook }}"
      ]
    }
  ]
}
</script>
