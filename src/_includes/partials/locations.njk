<section class="info-grid" aria-labelledby="location-heading">

  <article class="card card--paper card--tilt-r">
    <div class="card__file">// LOCATION.MAP</div>
    <h2 id="location-heading" class="card__title">{{ site.address.street | upper }}</h2>
    <address class="card__address">
      {{ site.address.street }}<br>
      {{ site.address.postalCode }} {{ site.address.city | upper }} · DANMARK
    </address>
    <a class="card__link" href="{{ site.address.mapsUrl }}" target="_blank" rel="noopener">
      FIND DEN PÅ KORTET ↗
    </a>
    <a class="card__link card__link--secondary"
       href="https://www.openstreetmap.org/?mlat=55.6792&amp;mlon=12.5710&amp;zoom=18"
       target="_blank" rel="noopener">
      [OSM ↗]
    </a>
  </article>

  {% include "partials/contact.njk" %}

</section>
