{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": [
        "http://localhost/index.html",
        "http://localhost/walk-in/index.html",
        "http://localhost/artister/index.html",
        "http://localhost/artister/simone/index.html",
        "http://localhost/privatlivspolitik/index.html",
        "http://localhost/en/index.html",
        "http://localhost/en/walk-in/index.html",
        "http://localhost/en/artists/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "uses-text-compression": "off",
        "is-crawlable": "off"
      }
    }
  }
}
